---
type Props = {
  title: string;
  description: string;
  canonicalPath?: string;
  image?: string;
  type?: "website" | "article";
  publishedTime?: string;
  author?: string;
};

const {
  title,
  description,
  canonicalPath = Astro.url.pathname,
  image = "/og.png",
  type = "website",
  publishedTime,
  author,
} = Astro.props;

const site = Astro.site ?? new URL("https://ochi.dev");
const canonicalUrl = new URL(canonicalPath, site);
const imageUrl = new URL(image, site);
---

<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl} />

<meta property="og:site_name" content="Ochi" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:image" content={imageUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content="Ochi - Green Observability" />
<meta property="og:locale" content="en_US" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageUrl} />

{
  type === "article" && publishedTime ? (
    <meta property="article:published_time" content={publishedTime} />
  ) : null
}
{type === "article" && author ? <meta property="article:author" content={author} /> : null}
