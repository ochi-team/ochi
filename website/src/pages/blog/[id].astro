---
import { getCollection, render } from "astro:content";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import BlogBackground from "../../components/BlogBackground.astro";
import "../../styles/global.css";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  // Sort by newest first
  const sortedPosts = posts.sort(
    (a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf(),
  );
  return sortedPosts.map((post, index) => ({
    params: { id: post.id },
    props: {
      post,
      prevPost: index < sortedPosts.length - 1 ? sortedPosts[index + 1] : null, // chronological "previous" is older (higher index)
      nextPost: index > 0 ? sortedPosts[index - 1] : null, // chronological "next" is newer (lower index)
    },
  }));
}

const { post, prevPost, nextPost } = Astro.props;
const { Content } = await render(post);
const authorName = post.data.author?.trim();
const authorAvatar = authorName
  ? `/avatars/${authorName.toLowerCase().replace(/\s+/g, "-")}.png`
  : null;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{post.data.title} - Ochi Blog</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link
      href="https://fonts.googleapis.com/css2?family=Numans&display=swap"
      rel="stylesheet"
    />
    <script
      src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"
    ></script>
    <style is:global>
      body {
        font-family: "Numans", sans-serif;
      }
      ::-webkit-scrollbar {
        width: 8px;
      }
      ::-webkit-scrollbar-track {
        background: #020817;
      }
      ::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.1);
        border-radius: 4px;
      }
      ::-webkit-scrollbar-thumb:hover {
        background: rgba(255, 255, 255, 0.2);
      }
      .blog-prose {
        color: #b8cad2;
        line-height: 1.85;
      }
      .blog-prose > :first-child {
        margin-top: 0;
      }
      .blog-prose > :last-child {
        margin-bottom: 0;
      }
      .blog-prose :where(h1, h2, h3, h4) {
        color: #ffffff;
        font-weight: 800;
        line-height: 1.25;
        letter-spacing: -0.02em;
        margin-top: 2.5rem;
        margin-bottom: 1rem;
      }
      .blog-prose h1 {
        font-size: clamp(2rem, 4vw, 2.5rem);
      }
      .blog-prose h2 {
        font-size: clamp(1.6rem, 3vw, 2rem);
      }
      .blog-prose h3 {
        font-size: clamp(1.35rem, 2.4vw, 1.65rem);
      }
      .blog-prose h4 {
        font-size: 1.2rem;
      }
      .blog-prose p {
        margin: 1.25rem 0;
      }
      .blog-prose :where(strong, b) {
        color: #ecf4f7;
        font-weight: 700;
      }
      .blog-prose :where(em, i) {
        color: #c8d7dd;
      }
      .blog-prose :where(ul, ol) {
        margin: 1.25rem 0;
        padding-left: 1.5rem;
      }
      .blog-prose ul {
        list-style: disc;
      }
      .blog-prose ol {
        list-style: decimal;
      }
      .blog-prose li {
        margin: 0.4rem 0;
      }
      .blog-prose li > :where(ul, ol) {
        margin: 0.7rem 0;
      }
      .blog-prose a {
        color: #6ee7b7;
        text-decoration: underline;
        text-decoration-thickness: 2px;
        text-underline-offset: 3px;
        transition: color 0.25s ease;
      }
      .blog-prose a:hover {
        color: #a7f3d0;
      }
      .blog-prose blockquote {
        margin: 1.6rem 0;
        padding: 0.35rem 1rem;
        border-left: 3px solid rgba(34, 197, 94, 0.55);
        color: #b9c8ce;
        font-style: italic;
        background: rgba(255, 255, 255, 0.02);
        border-radius: 0 0.45rem 0.45rem 0;
      }
      .blog-prose hr {
        border: 0;
        border-top: 1px solid rgba(255, 255, 255, 0.12);
        margin: 2.4rem 0;
      }
      .blog-prose :not(pre) > code {
        color: #c4f4dd;
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 0.375rem;
        padding: 0.12rem 0.42rem;
        font-size: 0.9em;
      }
      .blog-prose pre {
        margin: 1.5rem 0;
        border-radius: 0.9rem;
        border: 1px solid rgba(255, 255, 255, 0.1);
        overflow-x: auto;
      }
      .blog-prose :where(img, video) {
        margin: 1.8rem 0;
        border-radius: 0.85rem;
      }
      .blog-prose table {
        width: 100%;
        margin: 1.6rem 0;
        border-collapse: collapse;
        border: 1px solid rgba(255, 255, 255, 0.12);
      }
      .blog-prose th,
      .blog-prose td {
        border: 1px solid rgba(255, 255, 255, 0.08);
        padding: 0.6rem 0.75rem;
        text-align: left;
      }
      .blog-prose th {
        color: #ecf4f7;
        background: rgba(255, 255, 255, 0.03);
      }
    </style>
  </head>
  <body
    class="bg-[#020817] text-white antialiased selection:bg-[#22c55e] selection:text-[#020817] flex flex-col min-h-screen font-light text-lg"
  >
    <BlogBackground />
    <Header activePage="blog" />

    <main class="flex-grow pt-32 pb-24 relative z-10">
      <article class="max-w-3xl mx-auto px-6">
        <header class="mb-16">
          <a
            href="/blog"
            class="inline-flex items-center text-sm font-bold text-[#a854f7] hover:text-[#e9d5ff] transition-colors mb-8"
          >
            <iconify-icon icon="solar:arrow-left-linear" class="mr-2 text-base"
            ></iconify-icon>
            Back to Blog
          </a>
          <h1
            class="text-4xl md:text-5xl font-black tracking-tight mb-6 leading-tight"
          >
            {post.data.title}
          </h1>
          {
            authorName ? (
              <div class="inline-grid grid-cols-[auto_1fr] items-center gap-x-4 gap-y-2 px-3 py-2 text-base font-medium text-[#8FA3AB]">
                <img
                  src={authorAvatar}
                  alt={`${authorName} avatar`}
                  class="h-14 w-14 rounded-full object-cover row-span-2"
                />
                <span class="text-[#d7e6eb] font-semibold leading-none">By {authorName}</span>
                <span>
                  {
                    new Date(post.data.date).toLocaleDateString("en-US", {
                      month: "short",
                      day: "numeric",
                      year: "numeric",
                    })
                  }
                </span>
              </div>
            ) : (
              <div class="flex items-center gap-4 text-sm font-medium text-[#8FA3AB]">
                <span>
                  {
                    new Date(post.data.date).toLocaleDateString("en-US", {
                      month: "short",
                      day: "numeric",
                      year: "numeric",
                    })
                  }
                </span>
              </div>
            )
          }
        </header>

        <div class="blog-prose max-w-none">
          <Content />
        </div>

        <div
          class="mt-20 pt-10 border-t border-white/10 flex flex-col sm:flex-row justify-between items-center sm:items-stretch gap-6"
        >
          {
            prevPost ? (
              <a
                href={`/blog/${prevPost.id}`}
                class="group flex-1 flex flex-col w-full sm:w-auto items-start p-6 rounded-2xl bg-white/[0.02] border border-white/5 hover:border-[#22c55e]/30 transition-colors"
              >
                <span class="text-xs text-[#8FA3AB] font-bold uppercase tracking-wide mb-2 flex items-center gap-2 group-hover:text-[#22c55e] transition-colors">
                  <iconify-icon
                    icon="solar:arrow-left-linear"
                    class="text-sm group-hover:-translate-x-1 transition-transform"
                  />
                  Previous Post
                </span>
                <span class="text-lg font-bold text-white group-hover:text-[#22c55e] transition-colors">
                  {prevPost.data.title}
                </span>
              </a>
            ) : (
              <div class="flex-1" />
            )
          }

          {
            nextPost ? (
              <a
                href={`/blog/${nextPost.id}`}
                class="group flex-1 flex flex-col w-full sm:w-auto items-end text-right p-6 rounded-2xl bg-white/[0.02] border border-white/5 hover:border-[#a854f7]/30 transition-colors"
              >
                <span class="text-xs text-[#8FA3AB] font-bold uppercase tracking-wide mb-2 flex items-center gap-2 group-hover:text-[#a854f7] transition-colors">
                  Next Post
                  <iconify-icon
                    icon="solar:arrow-right-linear"
                    class="text-sm group-hover:translate-x-1 transition-transform"
                  />
                </span>
                <span class="text-lg font-bold text-white group-hover:text-[#a854f7] transition-colors">
                  {nextPost.data.title}
                </span>
              </a>
            ) : (
              <div class="flex-1" />
            )
          }
        </div>
      </article>
    </main>

    <Footer logoSrc="/logo.svg" />
  </body>
</html>
