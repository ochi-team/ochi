{
  "rules": {
    "allocator-first-param": "warn",
    "avoid-as": "warn",
    "case-convention": "warn",
    "homeless-try": "error",
    "line-length": ["warn", { "max_length": 120 }],
    "must-return-ref": "error",
    "no-catch-return": "warn",
    "no-return-try": "warn",
    "returned-stack-reference": "error",
    "suppressed-errors": "warn",
    "unsafe-undefined": "error",
    "unused-decls": "warn",
    "useless-error-return": "warn"
  }
}
